{
  "name": "oefa-jsf-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Scraper en TypeScript para el portal REPDIG del OEFA (PrimeFaces/JSF): extraccion de resoluciones y descarga de PDFs.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@types/node": "^22.20.1",
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.0",
    "pino": "^10.3.1",
    "tough-cookie": "^6.0.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/tough-cookie": "^4.0.5",
    "pino-pretty": "^13.1.3"
  }
}
