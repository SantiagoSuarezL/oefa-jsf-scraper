# URL del portal (la alternativa sin VPN)
OEFA_BASE_URL=https://publico.oefa.gob.pe/repdig/consulta/consultaTfa.xhtml

# Carpera de salida para PDFs descargados (relativa al CWD)
OEFA_OUTPUT_DIR=./output

# Archivo JSON con todos los registros extraídos
OEFA_JSON_FILE=./output/resoluciones.json

# Carpeta donde se guardan los PDFs
OEFA_PDF_DIR=./output/pdfs

# --- Paginación ---
# Filas por página que envía PrimeFaces (no cambiar sin inspeccionar el sitio)
OEFA_ROWS_PER_PAGE=10

# --- Descarga de PDFs ---
# Concurrency para descargar PDFs (2-4 recomendado; mayor puede disparar 429)
OEFA_DOWNLOAD_CONCURRENCY=2

# Delay entre descargas (ms) para no saturar al servidor
OEFA_DOWNLOAD_DELAY_MS=500

# Máximo de PDFs a descargar (0 = todos; útil para pruebas sin descargar el total)
OEFA_MAX_DOWNLOADS=0

# Traza de depuración de paginación (1/true = registra rango expediente/uuid por página)
OEFA_DEBUG_PAGINATION=0

# --- Retry ---
OEFA_RETRY_MAX_ATTEMPTS=5
OEFA_RETRY_BASE_DELAY_MS=1000
OEFA_RETRY_MAX_DELAY_MS=30000

# --- HTTP ---
OEFA_HTTP_TIMEOUT_MS=30000
OEFA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# --- Logging ---
# "debug" | "info" | "warn" | "error"
OEFA_LOG_LEVEL=info
